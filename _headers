# Cloudflare Pages reads this file to override its default caching.
# Everything here still gets ETag-based conditional caching (a cheap 304
# when nothing changed) — this just stops the browser/CDN from blindly
# serving a stale copy for hours after a deploy, which is what made a
# just-pushed CSS change look like it hadn't gone live. Small static site,
# low traffic — the extra revalidation round-trip costs nothing that
# matters here, and "always genuinely fresh" is worth more than shaving
# off that request.
/*
  Cache-Control: no-cache

# Cloudflare Pages applies its own higher-priority default caching to
# known static-asset file types (css/js/images) that the generic /* rule
# above didn't win against in testing — explicit, more specific paths to
# force it.
/assets/*
  Cache-Control: no-cache
/data/*
  Cache-Control: no-cache
/*.css
  Cache-Control: no-cache
/*.js
  Cache-Control: no-cache
